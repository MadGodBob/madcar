<launch>
  <node pkg="motor_drive" type="motor_driver_node.py" name="motor_driver" output="screen">
    <param name="frame_id" value="odom"/>
    <param name="child_frame_id" value="base_link"/>
    <param name="topic" value="/cmd_vel"/>
    <param name="v_max" value="0.6"/>
    <param name="cmd_timeout" value="0.5"/>
  </node>
</launch>